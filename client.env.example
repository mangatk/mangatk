# ==========================================
# Mangatk - Client Environment Variables
# ==========================================
# Rename this file to exactly: .env
# Place it in the same folder as docker-compose.yml
# ==========================================

# 1. Django Security Settings
# Make up a long, random string of characters here:
SECRET_KEY=django-insecure-replace-this-with-a-very-long-random-string
# KEEP THIS AS FALSE FOR PRODUCTION to avoid security leaks
DEBUG=False
# Type the IP address or domain name of the server here (e.g., 123.45.67.89 or example.com)
ALLOWED_HOSTS=*

# 2. Database Connection (PostgreSQL)
# This matches the "rootpassword" we put in the docker-compose.yml file.
DATABASE_URL=postgres://postgres:rootpassword@db:5432/mangatk

# 3. ImgBB API Key
# Put your ImgBB image uploading key here
IMGBB_API_KEY=put_your_imgbb_key_here

# 4. Auth0 / Authentication Keys
AUTH0_DOMAIN=your_auth0_domain_here
AUTH0_AUDIENCE=your_auth0_api_identifier_here
